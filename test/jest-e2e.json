{
  "moduleFileExtensions": ["ts", "js", "json"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "isolatedModules": true }]
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^@tact/(.*)$": "<rootDir>/../../packages/$1/src"
  },
  "setupFiles": ["<rootDir>/setup.ts"]
}
